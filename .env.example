# bgpeek environment configuration
# Copy to .env and adjust values for your deployment.

# --- PostgreSQL (used by compose.yaml) ---
POSTGRES_DB=bgpeek
POSTGRES_USER=bgpeek
POSTGRES_PASSWORD=                                  # REQUIRED — set a strong password

# --- Server ---
BGPEEK_HOST=0.0.0.0                                 # bind address for the web server (0.0.0.0 = all interfaces)
BGPEEK_PORT=8000                                    # listening TCP port for the web server
# BGPEEK_WORKERS=1                                  # number of Uvicorn worker processes
# BGPEEK_DEBUG=false                                # enable debug mode (verbose errors/logging; not recommended for production)

# --- Database ---
# BGPEEK_DATABASE_URL=postgresql://bgpeek:PASSWORD@postgres:5432/bgpeek
# (auto-constructed in compose.yaml from POSTGRES_* vars)
# BGPEEK_DB_POOL_MIN=2                              # minimum number of persistent DB connections in the pool
# BGPEEK_DB_POOL_MAX=10                             # maximum number of DB connections in the pool
# BGPEEK_DB_COMMAND_TIMEOUT=30                      # database statement timeout in seconds
# BGPEEK_AUTO_MIGRATE=true                          # run schema migrations automatically at startup

# --- Redis / Cache ---
# BGPEEK_REDIS_URL=redis://redis:6379/0
# BGPEEK_CACHE_TTL=60                               # query cache TTL in seconds

# --- JWT (REQUIRED for production) ---
BGPEEK_JWT_SECRET=                                  # REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# BGPEEK_JWT_ALGORITHM=HS256                        # JWT signing algorithm (default symmetric HMAC SHA-256)
# BGPEEK_JWT_EXPIRE_MINUTES=60                      # JWT access token lifetime in minutes

# --- Session ---
BGPEEK_SESSION_SECRET=                              # REQUIRED for OIDC — generate same as JWT_SECRET
# BGPEEK_ACCESS_MODE=guest                          # closed | guest | open (closed=login required, guest=anonymous restricted, open=anonymous full access)
# BGPEEK_PUBLIC_OUTPUT_LEVEL=restricted             # restricted | standard | full (controls output detail for public/guest users)
# BGPEEK_MAX_PREFIX_V4=24                           # Longest IPv4 prefix accepted at validation + kept in public output (8-32)
# BGPEEK_MAX_PREFIX_V6=48                           # Longest IPv6 prefix accepted at validation + kept in public output (16-128)

# --- OIDC ---
# BGPEEK_OIDC_ENABLED=false
# BGPEEK_OIDC_CLIENT_ID=
# BGPEEK_OIDC_CLIENT_SECRET=
# BGPEEK_OIDC_SERVER_URL=                           # e.g. https://keycloak.example.com/realms/bgpeek
# BGPEEK_OIDC_DISCOVERY_URL=                        # auto-derived from server_url if empty
# BGPEEK_OIDC_SCOPES=openid email profile
# BGPEEK_OIDC_ROLE_CLAIM=realm_access.roles
# BGPEEK_OIDC_ROLE_MAPPING=                         # JSON: {"bgpeek-admin": "admin", "bgpeek-noc": "noc"}
# BGPEEK_OIDC_DEFAULT_ROLE=public

# --- LDAP ---
# BGPEEK_LDAP_ENABLED=false
# BGPEEK_LDAP_SERVER=                               # e.g. ldap://ldap.example.com:389 or ldaps://...
# BGPEEK_LDAP_BIND_DN=                              # service account DN for search
# BGPEEK_LDAP_BIND_PASSWORD=
# BGPEEK_LDAP_BASE_DN=                              # e.g. ou=people,dc=example,dc=com
# BGPEEK_LDAP_USER_FILTER=(uid={username})
# BGPEEK_LDAP_USE_TLS=false
# BGPEEK_LDAP_ROLE_MAPPING=                         # JSON: {"cn=noc,ou=groups,dc=ex": "noc"}
# BGPEEK_LDAP_DEFAULT_ROLE=public
# BGPEEK_LDAP_EMAIL_ATTR=mail
# BGPEEK_LDAP_GROUP_ATTR=memberOf

# --- SSH ---
# BGPEEK_SSH_USERNAME=looking-glass                 # fallback when no credential assigned to device
# BGPEEK_SSH_TIMEOUT=30                             # connection/command timeout in seconds
# BGPEEK_SSH_TIMEOUT_TRACEROUTE=120                 # timeout in seconds for traceroute commands (often longer than regular queries)
# BGPEEK_SSH_KNOWN_HOSTS_POLICY=auto-add            # auto-add | strict
# BGPEEK_KEYS_DIR=/etc/bgpeek/keys                  # directory containing SSH private key files
# BGPEEK_ENCRYPTION_KEY=                            # Fernet key for encrypting stored passwords
#   Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Rate limiting ---
# BGPEEK_RATE_LIMIT_ENABLED=true
# BGPEEK_RATE_LIMIT_QUERY=30                        # queries per minute per IP
# BGPEEK_RATE_LIMIT_LOGIN=5                         # login attempts per minute per IP
# BGPEEK_RATE_LIMIT_API=60                          # API calls per minute per API key

# --- Parallel queries ---
# BGPEEK_MAX_PARALLEL_QUERIES=5

# --- Results ---
# BGPEEK_RESULT_TTL_DAYS=7                          # how long shared query results are kept

# --- Logging ---
# BGPEEK_SERVICE_NAME=bgpeek                        # 'service=<name>' label on every event; override per instance when shipping multiple bgpeeks into one log backend
# BGPEEK_LOG_LEVEL=info                             # debug | info | warning | error | critical
# BGPEEK_LOG_FORMAT=console                         # console (default, human) | json (NDJSON) | logfmt
# BGPEEK_LOG_SHIP_URL=                              # optional HTTP endpoint; empty disables shipping. Example: http://vl:9428/insert/jsonline?_msg_field=event&_time_field=timestamp&_stream_fields=service,level
# BGPEEK_LOG_SHIP_FORMAT=ndjson                     # ndjson | loki | elasticsearch
# BGPEEK_LOG_SHIP_HEADERS=                          # optional JSON object, e.g. {"Authorization":"Bearer xyz"}
# BGPEEK_LOG_SHIP_BATCH_SIZE=100                    # events per POST
# BGPEEK_LOG_SHIP_BATCH_TIMEOUT_SEC=2               # max seconds an event waits in queue
# BGPEEK_LOG_SHIP_QUEUE_MAX=10000                   # in-memory queue cap (drop-oldest on overflow)
# BGPEEK_LOG_SHIP_TIMEOUT_SEC=5                     # HTTP timeout for one shipping POST

# --- Audit ---
# BGPEEK_AUDIT_TTL_DAYS=90                          # 0 = keep forever
# BGPEEK_AUDIT_STDOUT=true                          # emit audit entries to the log stream in addition to PostgreSQL

# --- Circuit breaker ---
# BGPEEK_CIRCUIT_BREAKER_ENABLED=true
# BGPEEK_CIRCUIT_BREAKER_THRESHOLD=3                # consecutive failures before marking device down
# BGPEEK_CIRCUIT_BREAKER_COOLDOWN=300               # seconds before retrying a tripped device

# --- Device access ---
# BGPEEK_DEVICE_PUBLIC_BY_DEFAULT=true

# --- RPKI ---
# BGPEEK_RPKI_ENABLED=false                         # enable RPKI origin validation checks in query results
# BGPEEK_RPKI_API_URL=http://routinator:8323/api/v1/validity  # RTR/RPKI validator HTTP API endpoint (for example Routinator)
# BGPEEK_RPKI_TIMEOUT=5                             # RPKI API request timeout in seconds
# BGPEEK_RPKI_CACHE_TTL=3600                        # cache success responses for this many seconds
# BGPEEK_RPKI_ERROR_CACHE_TTL=60                    # cache API errors/failures for this many seconds

# --- i18n ---
# BGPEEK_DEFAULT_LANG=en
# BGPEEK_ENABLED_LANGUAGES=en,ru                     # allow-list of language codes; must include default_lang. Set to a single code (e.g. `en`) to serve one language regardless of Accept-Language.

# --- Target types ---
# BGPEEK_ALLOWED_TARGET_TYPES=ip,cidr,hostname       # allow-list of accepted target kinds. Drop `hostname` to reject DNS names (forces operators to enter IP/CIDR), drop `cidr` to reject prefix notation, etc. Rejections return HTTP 400 before any SSH/DNS work.

# --- API docs ---
# BGPEEK_DOCS_ENABLED=true                           # serve Swagger UI at /api/docs + OpenAPI schema at /api/openapi.json AND render the "API" link in the header. Set to false to return 404 on both endpoints AND hide the header link (they must toggle together — prod users should never see a dead link, and a visible endpoint stays findable for scanners).

# --- ASN ---
# BGPEEK_PRIMARY_ASN=                               # primary ASN (digits only); if unset, site_name falls back to "bgpeek" and the PeeringDB icon is hidden

# --- Links ---
# BGPEEK_LG_LINKS=                                  # JSON: [{"name": "Example LG", "url": "https://lg.example.com"}, ...]
# BGPEEK_PEERINGDB_LINK_ENABLED=true                # show/hide the PeeringDB icon in the top-right header (requires BGPEEK_PRIMARY_ASN to be set)

# --- Branding ---
# BGPEEK_BRAND_SITE_NAME=                           # if empty, defaults to "AS<BGPEEK_PRIMARY_ASN> bgpeek" when PRIMARY_ASN is set, otherwise just "bgpeek"
# BGPEEK_BRAND_PAGE_TITLES=                         # JSON object of per-page title suffix overrides (text after "·")
# BGPEEK_BRAND_SITE_DESCRIPTION=                    # if empty, defaults to "Open-source looking glass for ISPs and IX operators"
# BGPEEK_BRAND_LOGO_PATH=                           # if empty, defaults to /static/favicon.svg
# BGPEEK_BRAND_FAVICON_PATH=                        # if empty, defaults to /static/favicon.svg
# BGPEEK_BRAND_THEME_STORAGE_KEY=bgpeek-theme       # browser localStorage key for theme preference; set a unique value per installation to keep theme settings isolated between deployments
# BGPEEK_BRAND_FOOTER=                              # optional footer HTML shown after a "·" separator, for example: '<a href="https://example.com" target="_blank" rel="noopener noreferrer">example.com</a>'
# BGPEEK_BRAND_CUSTOM_CSS=                          # optional inline CSS appended to base template

# --- Paths (rarely need overriding) ---
# BGPEEK_CONFIG_DIR=/etc/bgpeek
# BGPEEK_STATIC_DIR=                                # defaults to built-in package static/
# BGPEEK_TEMPLATES_DIR=                             # defaults to built-in package templates/
